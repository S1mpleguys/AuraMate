menu "AuraMate Board Config"

config AURAMATE_I2C_PORT
    int "I2C controller index"
    range 0 1
    default 0
    help
        I2C controller index used by Bosch sensor daughter board.

config AURAMATE_I2C_SDA_GPIO
    int "I2C SDA GPIO"
    default -1
    help
        Keep -1 until the board pin map is confirmed.

config AURAMATE_I2C_SCL_GPIO
    int "I2C SCL GPIO"
    default -1
    help
        Keep -1 until the board pin map is confirmed.

config AURAMATE_I2C_FREQ_HZ
    int "I2C bus frequency (Hz)"
    range 100000 1000000
    default 400000
    help
        Default to Fast Mode for the sensor bus.

config AURAMATE_I2S_PORT
    int "I2S controller index"
    range 0 1
    default 0

config AURAMATE_I2S_MCLK_GPIO
    int "I2S MCLK GPIO"
    default -1

config AURAMATE_I2S_BCLK_GPIO
    int "I2S BCLK GPIO"
    default -1

config AURAMATE_I2S_WS_GPIO
    int "I2S WS/LRCK GPIO"
    default -1

config AURAMATE_I2S_DOUT_GPIO
    int "I2S DOUT GPIO"
    default -1

config AURAMATE_I2S_DIN_GPIO
    int "I2S DIN GPIO"
    default -1

config AURAMATE_LCD_HOST_ID
    int "LCD SPI host index"
    range 0 3
    default 1

config AURAMATE_LCD_SCLK_GPIO
    int "LCD SCLK GPIO"
    default -1

config AURAMATE_LCD_MOSI_GPIO
    int "LCD MOSI GPIO"
    default -1

config AURAMATE_LCD_CS_GPIO
    int "LCD CS GPIO"
    default -1

config AURAMATE_LCD_DC_GPIO
    int "LCD DC GPIO"
    default -1

config AURAMATE_LCD_RST_GPIO
    int "LCD RST GPIO"
    default -1

config AURAMATE_LCD_BL_GPIO
    int "LCD backlight GPIO"
    default -1

config AURAMATE_RGB_GPIO
    int "RGB light GPIO"
    default -1
    help
        Data pin for RGB strip or status LED.

endmenu
